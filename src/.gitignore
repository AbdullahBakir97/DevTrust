# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/
*.iml

# Local environment
.env
.env.local
.env.*.local
*.local

# Build / dependency output
node_modules/
dist/
build/
target/
__pycache__/
*.pyc
.pytest_cache/
coverage/
