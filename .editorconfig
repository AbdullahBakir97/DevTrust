# EditorConfig is awesome: https://EditorConfig.org
# Top-most file in the monorepo.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,jsx,ts,tsx,json,jsonc,yaml,yml,toml,vue,svelte,html,css,scss,sass,less,md,mdx}]
indent_size = 2

[Makefile]
indent_style = tab

[*.go]
indent_style = tab

[{*.bat,*.cmd}]
end_of_line = crlf

[*.{ps1,psm1,psd1}]
end_of_line = crlf
indent_size = 4
